<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="bark" />
		<Option pch_mode="2" />
		<Option compiler="gcc-mingw32" />
		<Option virtualFolders="bark/" />
		<Build>
			<Target title="Release">
				<Option output="bin/Release/bark" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="mingw_53_32bit" />
				<Option projectCompilerOptionsRelation="-1" />
				<Option projectLinkerOptionsRelation="-1" />
				<Option projectIncludeDirsRelation="-1" />
				<Option projectResourceIncludeDirsRelation="-1" />
				<Option projectLibDirsRelation="-1" />
				<MakeCommands>
					<Build command="" />
					<CompileFile command="" />
					<Clean command="" />
					<DistClean command="" />
					<AskRebuildNeeded command="" />
					<SilentBuild command=" &gt; $(CMD_NULL)" />
				</MakeCommands>
			</Target>
		</Build>
		<Unit filename="bark.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="bark.h">
			<Option virtualFolder="bark/" />
		</Unit>
		<Unit filename="bark_ext.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="bark_types.h">
			<Option virtualFolder="bark/" />
		</Unit>
		<Unit filename="main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
